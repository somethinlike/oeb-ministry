---
/**
 * Bible reader — dynamic route that handles all reading paths:
 *
 * /app/read                    → translation picker grid
 * /app/read/oeb-us             → book picker for OEB
 * /app/read/oeb-us/jhn         → chapter picker for John
 * /app/read/oeb-us/jhn/3       → workspace: split-pane reader + annotations
 *
 * Uses Astro's [...path] catch-all route to handle all depths.
 */
import AppLayout from "../../../layouts/AppLayout.astro";
import { BookPicker } from "../../../components/BookPicker";
import { ChapterPicker } from "../../../components/ChapterPicker";
import { Workspace } from "../../../components/workspace";
import { UserTranslationGrid } from "../../../components/UserTranslationGrid";
import { SUPPORTED_TRANSLATIONS, DEFAULT_TRANSLATION, BOOK_BY_ID } from "../../../lib/constants";
import { isValidBookId } from "../../../lib/verse-ref";

// Parse the URL path segments
const pathStr = Astro.params.path || "";
const segments = pathStr ? pathStr.split("/") : [];

// ── Determine which view to render based on URL depth ──

let view: "translation" | "book" | "chapter" | "read" = "translation";
let translation = "";
let book = "";
let chapter = 0;

if (segments.length === 0) {
  // /app/read → show translation picker (no more auto-redirect!)
  view = "translation";
}

if (segments.length >= 1) {
  translation = segments[0];
  // User translations (prefixed "user-") are stored client-side in IndexedDB,
  // so we can't validate them on the server. Let them through.
  const isUserTranslation = translation.startsWith("user-");
  const validTranslation = isUserTranslation || SUPPORTED_TRANSLATIONS.some(t => t.id === translation);
  if (!validTranslation) {
    return Astro.redirect(`/app/read`);
  }
  view = "book";
}

if (segments.length >= 2) {
  book = segments[1];
  // For user translations, skip book ID validation — their book list
  // lives in IndexedDB, not in our static BOOKS array
  const isUserTranslation = translation.startsWith("user-");
  if (!isUserTranslation && !isValidBookId(book)) {
    return Astro.redirect(`/app/read/${translation}`);
  }
  view = "chapter";
}

if (segments.length >= 3) {
  chapter = parseInt(segments[2], 10);
  const isUserTranslation = translation.startsWith("user-");
  if (isUserTranslation) {
    // User translations: only validate that chapter is a positive number.
    // Actual chapter existence is checked client-side.
    if (isNaN(chapter) || chapter < 1) {
      return Astro.redirect(`/app/read/${translation}/${book}`);
    }
  } else {
    const bookInfo = BOOK_BY_ID.get(book as any);
    if (!bookInfo || isNaN(chapter) || chapter < 1 || chapter > bookInfo.chapters) {
      return Astro.redirect(`/app/read/${translation}/${book}`);
    }
  }
  view = "read";
}

// For user translations, book name resolves client-side. Use the book ID as fallback.
const bookDisplayName = BOOK_BY_ID.get(book as any)?.name ?? book;

// Page titles that make sense to the user
const titles: Record<string, string> = {
  translation: "Choose a Bible",
  book: "Choose a Book",
  chapter: `${bookDisplayName} — Choose a Chapter`,
  read: `${bookDisplayName} ${chapter}`,
};

// Auth guard — redirect to sign-in if not authenticated (server-side)
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(`/auth/signin?returnUrl=${encodeURIComponent(Astro.url.pathname)}`);
}
---

<AppLayout title={titles[view]} fullWidth={view === "read"}>
  {/* Translation picker grid — shows all available Bibles */}
  {view === "translation" && (
    <div>
      <h1 class="text-2xl font-bold text-heading mb-6">Choose a Bible</h1>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {SUPPORTED_TRANSLATIONS.map((t) => (
          <a
            href={`/app/read/${t.id}`}
            class="rounded-lg border border-edge bg-panel p-6
                   hover:border-accent hover:bg-accent-soft
                   focus:outline-none focus:ring-2 focus:ring-ring
                   transition-colors duration-150"
          >
            <h2 class="text-lg font-semibold text-heading">{t.name}</h2>
            <p class="text-sm text-muted mt-1">{t.license}</p>
            {t.hasApocrypha && (
              <span class="mt-2 inline-block rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-700">
                Includes Deuterocanon
              </span>
            )}
          </a>
        ))}
      </div>
      {/* User-uploaded translations from IndexedDB (client-side only) */}
      <UserTranslationGrid client:load />
    </div>
  )}

  {/* Breadcrumb navigation — for non-workspace views */}
  {(view === "book" || view === "chapter") && (
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex flex-wrap items-center gap-2 text-sm text-muted">
        <li>
          <a href="/app/read" class="hover:text-heading focus:outline-none focus:ring-2 focus:ring-ring rounded">
            Bible
          </a>
        </li>
        <li class="flex items-center gap-2">
          <span aria-hidden="true">/</span>
          <a href={`/app/read/${translation}`} class="hover:text-heading focus:outline-none focus:ring-2 focus:ring-ring rounded">
            {SUPPORTED_TRANSLATIONS.find(t => t.id === translation)?.name ?? translation}
          </a>
        </li>
        {view === "chapter" && (
          <li class="flex items-center gap-2">
            <span aria-hidden="true">/</span>
            <span class="font-medium text-heading">
              {BOOK_BY_ID.get(book as any)?.name ?? book}
            </span>
          </li>
        )}
      </ol>
    </nav>
  )}

  {/* View-specific content */}
  {view === "book" && (
    <BookPicker translation={translation} client:load />
  )}

  {view === "chapter" && (
    <ChapterPicker translation={translation} book={book} client:load />
  )}

  {/* Workspace: split-pane reader + annotations */}
  {view === "read" && (
    <Workspace
      translation={translation}
      book={book}
      chapter={chapter}
      userId={user?.id ?? null}
      userEmail={user?.email ?? null}
      client:load
    />
  )}
</AppLayout>
