---
/**
 * Community page — browse published CC0 content from all users.
 *
 * Two tabs:
 * - "Notes" — individual published annotations (existing PublicFeed)
 * - "Devotionals" — published devotional bibles with fork/copy support
 *
 * Grandmother Principle:
 * - "Community" not "Public Content Repository"
 * - Accessible to all authenticated users
 */
import AppLayout from "../../layouts/AppLayout.astro";
import { CommunityTabs } from "../../components/CommunityTabs";

const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(`/auth/signin?returnUrl=${encodeURIComponent(Astro.url.pathname)}`);
}
---

<AppLayout title="Community">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-2xl font-bold text-heading mb-2">Community</h2>
    <p class="text-sm text-muted mb-6">
      Content shared freely by the community. Everything here is CC0 &mdash; read,
      share, and build on it however you like.
    </p>
    <CommunityTabs userId={user.id} client:load />
  </div>
</AppLayout>
